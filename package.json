{
  "name": "bullet-lens",
  "version": "0.1.0",
  "private": true,
  "description": "Modern web-based 3D visualization for x3p bullet scans",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
